generator client {
  provider = "prisma-client"
  output   = "../packages/db/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PositionStatus {
  OPEN
  CLOSED
  LIQUIDATED
}

enum OrderStatus {
  OPEN
  FILLED
  PARTIALLY_FILLED
  CANCELLED
}

enum OrderType {
  MARKET
  LIMIT
}

enum PositionType {
  LONG
  SHORT
}

model User {
  id         Int         @id @default(autoincrement())
  username   String      @unique
  password   String

  collateral Collateral?
  positions  Position[]
  orders     Order[]
  fills      Fill[]
}

model Collateral {
  id        Int      @id @default(autoincrement())
  available BigInt
  locked    BigInt
  updatedAt DateTime @updatedAt

  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
}

model Position {
  id                Int            @id @default(autoincrement())
  market            String
  type              PositionType
  qty               BigInt
  leverage          Int
  margin            BigInt
  liquidationPrice  BigInt
  pnl               BigInt
  averagePrice      BigInt
  status            PositionStatus @default(OPEN)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  userId            Int
  user              User           @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Order {
  id          Int          @id @default(autoincrement())
  market      String
  type        PositionType
  leverage    Int
  qty         BigInt
  orderType   OrderType
  price       BigInt
  status      OrderStatus
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userId      Int
  user        User         @relation(fields: [userId], references: [id])

  makerFills  Fill[]       @relation("MakerFills")
  takerFills  Fill[]       @relation("TakerFills")

  @@index([userId, status])
  @@index([market, status])
}

model Fill {
  id           Int      @id @default(autoincrement())
  price        BigInt
  qty          BigInt
  market       String
  marketId     String
  makerOrderId Int
  takerOrderId Int
  createdAt    DateTime @default(now())

  makerOrder   Order    @relation("MakerFills", fields: [makerOrderId], references: [id])
  takerOrder   Order    @relation("TakerFills", fields: [takerOrderId], references: [id])

  userId       Int
  user         User     @relation(fields: [userId], references: [id])

  @@index([market, createdAt])
}
